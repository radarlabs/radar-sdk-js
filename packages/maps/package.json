{
  "name": "@radarlabs/maps-plugin",
  "version": "5.0.0-beta.2",
  "description": "Maps plugin for radar-sdk-js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "dist/radar.css",
  "files": [
    "dist",
    "cdn",
    "src"
  ],
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/radarlabs/radar-sdk-js.git",
    "directory": "packages/maps"
  },
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "maplibre-gl": "^2.4.0 || ^3.0.0 || ^4.0.0 || ^5.0.1",
    "radar-sdk-js": ">=5.0.0-beta.1"
  },
  "devDependencies": {
    "maplibre-gl": "^5.3.0",
    "radar-sdk-js": "^5.0.0-beta.1",
    "rollup-plugin-postcss": "^4.0.2"
  }
}
